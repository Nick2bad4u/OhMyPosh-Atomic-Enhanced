{
  "segment_insertions": [
    {
      "block": {
        "type": "rprompt",
        "alignment": "right"
      },
      "after_alias": "java-rprompt",
      "before_alias": "upgrade-rprompt",
      "segments": [
        {
          "leading_diamond": "",
          "min_width": 80,
          "placeholder": "",
          "style": "diamond",
          "timeout": 1500,
          "trailing_diamond": "",
          "alias": "svn-rprompt",
          "background": "p:blue_tooltip",
          "foreground": "p:navy_text",
          "options": {
            "fetch_status": true
          },
          "template": " <b> SVN {{ .Branch }} • r{{ .BaseRev }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }}</b> ",
          "type": "svn"
        },
        {
          "leading_diamond": "",
          "min_width": 80,
          "placeholder": "",
          "style": "diamond",
          "timeout": 1500,
          "trailing_diamond": "",
          "alias": "sapling-rprompt",
          "background": "p:green_valid_line",
          "foreground": "p:white",
          "options": {
            "fetch_status": true
          },
          "template": " <b>{{ if .Bookmark }} {{ .Bookmark }}{{ else }} {{ .ShortHash }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}</b> ",
          "type": "sapling"
        },
        {
          "leading_diamond": "",
          "min_width": 80,
          "placeholder": "",
          "style": "diamond",
          "timeout": 1500,
          "trailing_diamond": "",
          "alias": "plastic-rprompt",
          "background": "p:tooling_purple",
          "background_templates": [
            "{{ if and .Changed .Behind }}p:red_alert{{ else if .Changed }}p:orange_warning{{ else if .Behind }}p:purple_behind{{ else }}p:tooling_purple{{ end }}"
          ],
          "foreground": "p:white",
          "options": {
            "fetch_status": true
          },
          "template": " <b>󰘬 Plastic {{ .Selector }}{{ if .Status.Changed }}  {{ .Status.String }}{{ end }}{{ if .Behind }} ⇣{{ end }}</b> ",
          "type": "plastic"
        },
        {
          "leading_diamond": "",
          "min_width": 80,
          "placeholder": "",
          "style": "diamond",
          "timeout": 1500,
          "trailing_diamond": "",
          "alias": "mercurial-rprompt",
          "background": "p:tooling_yellow",
          "foreground": "p:navy_text",
          "options": {
            "fetch_status": true,
            "native_fallback": false
          },
          "template": " <b> hg {{ .Branch }}{{ if .LocalCommitNumber }} ({{ .LocalCommitNumber }}:{{ .ChangeSetIDShort }}){{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}</b> ",
          "type": "mercurial"
        },
        {
          "leading_diamond": "",
          "min_width": 80,
          "placeholder": "",
          "style": "diamond",
          "timeout": 1500,
          "trailing_diamond": "",
          "alias": "jujutsu-rprompt",
          "background": "p:purple_exec",
          "foreground": "p:white",
          "options": {
            "fetch_status": true,
            "ignore_working_copy": false,
            "fetch_ahead_counter": true,
            "ahead_icon": "⇡"
          },
          "template": " <b>󰘬 jj {{ .ChangeID }}{{ if .ClosestBookmarks }} • {{ .ClosestBookmarks }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}</b> ",
          "type": "jujutsu"
        },
        {
          "leading_diamond": "",
          "min_width": 80,
          "placeholder": "",
          "style": "diamond",
          "timeout": 1500,
          "trailing_diamond": "",
          "alias": "fossil-rprompt",
          "background": "p:yellow_bright",
          "foreground": "p:navy_text",
          "template": " <b> Fossil {{ .Branch }}{{ if .Status.Changed }}  {{ .Status.String }}{{ end }}</b> ",
          "type": "fossil"
        },
        {
          "leading_diamond": "",
          "min_width": 80,
          "placeholder": "",
          "style": "diamond",
          "timeout": 1500,
          "trailing_diamond": "",
          "alias": "dvc-rprompt",
          "background": "p:tooling_purple",
          "foreground": "p:white",
          "template": " <b> DVC{{ if .Status.Changed }}  {{ .Status.String }}{{ else }} {{ end }}</b> ",
          "type": "dvc"
        }
      ]
    }
  ],
